#!/usr/bin/env python3
"""Entry point for the installable CLI helper."""

from __future__ import annotations

import os
from pathlib import Path
import sys


def _ensure_repo_root() -> None:
    # Ensure backend module resolves when running from a sibling directory.
    this_dir = os.path.dirname(os.path.abspath(__file__))
    repo_root = os.path.abspath(os.path.join(this_dir, os.pardir))
    sys.path.insert(0, repo_root)


def _maybe_reexec_local_venv() -> None:
    this_dir = Path(__file__).resolve().parent
    repo_root = this_dir.parent
    venv_python = repo_root / ".venv" / "bin" / "python"
    if not venv_python.exists():
        return
    active_prefix = Path(getattr(sys, "prefix", "")).resolve()
    expected_prefix = (repo_root / ".venv").resolve()
    if active_prefix == expected_prefix:
        return
    os.execv(str(venv_python), [str(venv_python), str(Path(__file__).resolve()), *sys.argv[1:]])


def _main() -> int:
    _maybe_reexec_local_venv()
    _ensure_repo_root()
    from backend.cli import main

    return main()


if __name__ == "__main__":
    raise SystemExit(_main())
